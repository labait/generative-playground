# Replicate
REPLICATE_API_TOKEN=r8_xxxx

# Microsoft Entra ID (Azure AD)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Session & URLs
SESSION_SECRET=change-me-to-a-random-string
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5173
# Same public URL the browser uses (for Replicate fetching /media/public/:token)
# In production: https://ai.laba.edu

# PostgreSQL
DATABASE_URL=postgres://laba:laba@localhost:5432/laba
POSTGRES_PASSWORD=laba

# Cookie security (set to true in production with HTTPS)
COOKIE_SECURE=false

# Optional: comma-separated emails promoted to admin on login
BOOTSTRAP_ADMIN_EMAILS=admin@laba.edu

# OAuth redirect (default: FRONTEND_URL + /auth/callback)
# OAUTH_REDIRECT_URI=https://ai.laba.edu/auth/callback

# Frontend build (Docker)
VITE_API_URL=
